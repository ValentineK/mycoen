
if [ -d "/usr/local/opt/util-linux" ]; then
    export PATH="/usr/local/opt/util-linux/bin:$PATH"
    export PATH="/usr/local/opt/util-linux/sbin:$PATH"
fi

#compdef pio
_pio() {
  eval $(env COMMANDLINE="${words[1,$CURRENT]}" _PIO_COMPLETE=complete-zsh  pio)
}
if [[ "$(basename -- ${(%):-%x})" != "_pio" ]]; then
  compdef _pio pio
fi

glop() {
  git log --oneline --no-decorate --oneline origin/master..HEAD | \
    awk '{print "\* \["substr($0, 9, 1000)"\]""\("substr($0, 0, 7)"\)" }'
}

export PATH="/usr/local/opt/python/libexec/bin:$PATH"
export PATH="/usr/local/sbin:$PATH"

### Bashhub.com Installation
export BH_URL=https://bashhub.konov.su
export BH_FILTER="(-p)"
# check if command is filtered
# bashhub filter "mysql -u root -p plain-text-password"
if [ -f ~/.bashhub/bashhub.zsh ]; then
    source ~/.bashhub/bashhub.zsh
fi

### ATUIN Installation
export ATUIN_CONFIG_DIR="$HOME/.atuin"
export ATUIN_NOBIND="true"
eval "$(atuin init zsh)"

bindkey '^r' _atuin_search_widget

zle -N _atuinr_widget_fzf _atuinr_fzf

_atuinr_fzf() {
    atuin history list --cmd-only | fzf
}
bindkey '^r' _atuin_search_widget

#https://pastebin.com/RXxU6rT4
#bindkey '^[[A' _atuinr_widget_fzf
#bindkey '^[OA' _atuinr_widget_fzf

export PATH="$HOME/go/bin:$PATH"

test -e "${HOME}/.iterm2_shell_integration.zsh" && source "${HOME}/.iterm2_shell_integration.zsh"

export LANG="en_US.UTF-8"

source /usr/local/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source /usr/local/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

autoload -U +X bashcompinit && bashcompinit
complete -o nospace -C /usr/local/Cellar/tfenv/3.0.0/versions/0.14.5/terraform terraform

export AWS_ACCESS_KEY_ID=REDACTED_AWS_KEY_ID
export AWS_SECRET_ACCESS_KEY=REDACTED_AWS_SECRET_KEY
