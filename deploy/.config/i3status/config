# i3status config
# See `man i3status`

general {
    colors = true
    interval = 5
    color_good     = "#a6e3a1"
    color_degraded = "#f9e2af"
    color_bad      = "#f38ba8"
}

order += "disk /"
order += "memory"
order += "cpu_usage"
order += "tztime local"

disk "/" {
    format = " %avail"
}

memory {
    format = " %used / %total"
    threshold_degraded = "1G"
    threshold_critical = "200M"
}

cpu_usage {
    format = " %usage"
}

tztime local {
    format = " %Y-%m-%d %H:%M"
}
